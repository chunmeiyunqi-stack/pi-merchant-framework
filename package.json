{
    "name":  "pi-merchant-framework",
    "version":  "0.1.0",
    "private":  true,
    "description":  "White-label merchant application framework for Pi Network ecosystem",
    "scripts":  {
    "postinstall": "prisma generate",
                    "dev":  "turbo run dev",
                    "build":  "turbo run build",
                    "lint":  "turbo run lint",
                    "type-check":  "turbo run type-check",
                    "db:generate":  "prisma generate",
                    "db:migrate":  "prisma migrate dev",
                    "db:push":  "prisma db push",
                    "db:seed":  "tsx prisma/seed.ts",
                    "db:studio":  "prisma studio"
                },
    "devDependencies":  {
                            "turbo":  "^2.0.0",
                            "typescript":  "^5.4.0",
                            "prisma":  "^5.12.0",
                            "@prisma/client":  "^5.12.0",
                            "tsx":  "^4.7.0"
                        },
    "engines":  {
                    "node":  "\u003e=18.0.0",
                    "pnpm":  "\u003e=8.0.0"
                },
    "packageManager":  "pnpm@8.15.0",
    "prisma":  {
                   "seed":  "tsx prisma/seed.ts"
               }
}
