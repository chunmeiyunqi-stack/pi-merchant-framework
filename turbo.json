{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "PGHOST",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_PASSWORD",
    "PGUSER",
    "NEON_PROJECT_ID",
    "POSTGRES_URL_NO_SSL",
    "PGPASSWORD",
    "POSTGRES_DATABASE",
    "POSTGRES_PRISMA_URL",
    "POSTGRES_URL",
    "PGHOST_UNPOOLED",
    "POSTGRES_USER",
    "POSTGRES_HOST",
    "DATABASE_URL_UNPOOLED",
    "PGDATABASE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "apps/web/.next/**", "!apps/web/.next/cache/**"],
      "env": ["PI_API_KEY", "NEXT_PUBLIC_PI_SANDBOX"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
