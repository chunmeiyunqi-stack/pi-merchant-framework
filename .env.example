# ==============================================
# Pi Merchant Framework — 环境变量模板
# 复制此文件为 .env，填写真实值后运行项目
# ==============================================

# ── 数据库 ──────────────────────────────────────
# PostgreSQL 连接字符串（本地开发使用 localhost）
DATABASE_URL="postgresql://user:password@localhost:5432/pi_merchant_db"

# ── Pi Network 配置 ──────────────────────────────
# 从 Pi Developer Portal 获取的 API Key
PI_API_KEY="your_pi_api_key"

# 是否启用沙盒模式（true=测试网，false=主网）
PI_SANDBOX=true

# Pi Platform API 基础地址（通常不需要修改）
PI_PLATFORM_API_BASE="https://api.minepi.com"

# ── 应用地址 ─────────────────────────────────────
# 商户前台访问地址（Next.js web app）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 商户后台访问地址（Next.js admin app）
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# ── 认证配置 ─────────────────────────────────────
# NextAuth.js 密钥（生产环境请使用随机字符串：openssl rand -base64 32）
NEXTAUTH_SECRET="your_nextauth_secret_min_32_chars"

# NextAuth.js 回调地址（与前台地址保持一致）
NEXTAUTH_URL="http://localhost:3000"

# ── 商户配置 ─────────────────────────────────────
# 单租户模式下的默认商户 ID（对应 merchants 表中的 id）
DEFAULT_MERCHANT_ID="your_merchant_id"

# ── 安全 ─────────────────────────────────────────
# JWT 签名密钥（用于内部 API 认证，与 NEXTAUTH_SECRET 可不同）
JWT_SECRET="your_jwt_secret_min_32_chars"

# ── 可选：邮件服务（用于通知） ──────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="noreply@example.com"
# SMTP_PASS="your_smtp_password"
